{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homelabos.local/schemas/manifest.schema.json",
  "title": "HomelabOS Plugin Manifest",
  "type": "object",
  "required": ["id", "name", "version", "api_version", "components"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "name": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "api_version": { "type": "integer", "const": 2 },
    "requires": {
      "type": "object",
      "properties": { "core": { "type": "string" } }
    },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "backend": { "type": "string", "description": "Python entry module, e.g. main.py" },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "name", "entry"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["widget", "app", "action"] },
          "name": { "type": "string" },
          "icon": { "type": "string" },
          "entry": { "type": "string" },
          "size": { "type": "object", "properties": { "w": { "type": "integer" }, "h": { "type": "integer" } } },
          "min_size": { "type": "object", "properties": { "w": { "type": "integer" }, "h": { "type": "integer" } } },
          "settings": { "type": "array" }
        }
      }
    }
  }
}
