{
  "$defs": {
    "ComponentSize": {
      "additionalProperties": false,
      "properties": {
        "w": {
          "minimum": 1,
          "title": "W",
          "type": "integer"
        },
        "h": {
          "minimum": 1,
          "title": "H",
          "type": "integer"
        }
      },
      "required": [
        "w",
        "h"
      ],
      "title": "ComponentSize",
      "type": "object"
    },
    "ManifestComponent": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "type": {
          "enum": [
            "widget",
            "app",
            "action"
          ],
          "title": "Type",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "entry": {
          "description": "HTML entry path relative to plugin root, e.g. src/widget.html",
          "title": "Entry",
          "type": "string"
        },
        "icon": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Icon"
        },
        "size": {
          "anyOf": [
            {
              "$ref": "#/$defs/ComponentSize"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "min_size": {
          "anyOf": [
            {
              "$ref": "#/$defs/ComponentSize"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "settings": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/WidgetSetting"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Settings"
        }
      },
      "required": [
        "id",
        "type",
        "name",
        "entry"
      ],
      "title": "ManifestComponent",
      "type": "object"
    },
    "ManifestRequires": {
      "additionalProperties": false,
      "properties": {
        "core": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Minimum HomelabOS core semver",
          "title": "Core"
        }
      },
      "title": "ManifestRequires",
      "type": "object"
    },
    "SettingOption": {
      "additionalProperties": false,
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "label",
        "value"
      ],
      "title": "SettingOption",
      "type": "object"
    },
    "WidgetSetting": {
      "additionalProperties": false,
      "description": "Declarative widget setting field (manifest components.settings).",
      "properties": {
        "key": {
          "title": "Key",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "type": {
          "enum": [
            "text",
            "number",
            "boolean",
            "select",
            "password"
          ],
          "title": "Type",
          "type": "string"
        },
        "default": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default"
        },
        "options": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/SettingOption"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Options"
        }
      },
      "required": [
        "key",
        "label",
        "type"
      ],
      "title": "WidgetSetting",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Plugin manifest.json \u2014 source of truth for bundled and installed plugins.",
  "properties": {
    "id": {
      "pattern": "^[a-z][a-z0-9-]*$",
      "title": "Id",
      "type": "string"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "version": {
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "title": "Version",
      "type": "string"
    },
    "api_version": {
      "const": 1,
      "default": 1,
      "title": "Api Version",
      "type": "integer"
    },
    "requires": {
      "anyOf": [
        {
          "$ref": "#/$defs/ManifestRequires"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "dependencies": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Dependencies"
    },
    "backend": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Python entry module, e.g. main.py",
      "title": "Backend"
    },
    "components": {
      "items": {
        "$ref": "#/$defs/ManifestComponent"
      },
      "minItems": 1,
      "title": "Components",
      "type": "array"
    }
  },
  "required": [
    "id",
    "name",
    "version",
    "components"
  ],
  "title": "HomelabOS Plugin Manifest",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homelabos.local/schemas/manifest.schema.json"
}
