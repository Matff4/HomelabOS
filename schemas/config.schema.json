{
  "additionalProperties": false,
  "description": "System-wide UI preferences persisted in data/config.json.",
  "properties": {
    "timeFormat": {
      "default": "24",
      "enum": [
        "12",
        "24"
      ],
      "title": "Timeformat",
      "type": "string"
    },
    "ramFormat": {
      "default": "percent",
      "enum": [
        "percent",
        "absolute"
      ],
      "title": "Ramformat",
      "type": "string"
    },
    "theme": {
      "default": "dark",
      "enum": [
        "dark",
        "light"
      ],
      "title": "Theme",
      "type": "string"
    },
    "barHeight": {
      "default": "medium",
      "enum": [
        "small",
        "medium",
        "big"
      ],
      "title": "Barheight",
      "type": "string"
    },
    "widgetBarHeight": {
      "default": "medium",
      "enum": [
        "small",
        "medium",
        "big"
      ],
      "title": "Widgetbarheight",
      "type": "string"
    },
    "accentColor": {
      "default": "blue",
      "enum": [
        "blue",
        "green",
        "purple",
        "red",
        "orange",
        "yellow"
      ],
      "title": "Accentcolor",
      "type": "string"
    },
    "marketplaceUrl": {
      "anyOf": [
        {
          "format": "uri",
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": "https://raw.githubusercontent.com/Matff4/HomelabOS-Plugins/master/index.json",
      "title": "Marketplaceurl"
    },
    "paneCount": {
      "default": 1,
      "maximum": 8,
      "minimum": 1,
      "title": "Panecount",
      "type": "integer"
    }
  },
  "title": "HomelabOS System Config",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homelabos.local/schemas/config.schema.json"
}
